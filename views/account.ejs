<%- include('partials/header', { title: 'My Account' }) %>
<%- include('partials/sidebar', { user: user }) %>
<div class="account-container">
    <h1>My Account</h1>
    <% if (error) { %><div class="error-message"><%= error %></div><% } %>
    <% if (success) { %><div class="success-message"><%= success %></div><% } %>
    
    <div class="account-section">
        <h2>Profile Information</h2>
        <form method="POST" action="/account/update">
            <div class="form-row">
                <div class="input-group">
                    <label>Full Name</label>
                    <input type="text" name="name" value="<%= profile ? profile.name : user.name %>" required>
                </div>
                <div class="input-group">
                    <label>Email</label>
                    <input type="email" name="email" value="<%= profile ? profile.email : user.email %>" required>
                </div>
            </div>
            <div class="form-row">
                <div class="input-group">
                    <label>Phone</label>
                    <input type="tel" name="phone" value="<%= profile ? profile.phone : '' %>">
                </div>
                <div class="input-group">
                    <label>Address</label>
                    <input type="text" name="address" value="<%= profile ? profile.address : '' %>">
                </div>
            </div>
            <div class="form-row">
                <div class="input-group">
                    <label>Gender</label>
                    <select name="gender">
                        <option value="">Select</option>
                        <option value="male" <%= (profile && profile.gender === 'male') ? 'selected' : '' %>>Male</option>
                        <option value="female" <%= (profile && profile.gender === 'female') ? 'selected' : '' %>>Female</option>
                        <option value="other" <%= (profile && profile.gender === 'other') ? 'selected' : '' %>>Other</option>
                    </select>
                </div>
                <div class="input-group">
                    <label>Date of Birth</label>
                    <input type="date" name="dob" value="<%= profile ? profile.dob : '' %>">
                </div>
            </div>
            <button type="submit" class="btn-primary">Update Profile</button>
        </form>
    </div>

    <div class="account-section">
        <h2>Change Password</h2>
        <form method="POST" action="/account/change-password">
            <div class="form-row">
                <div class="input-group">
                    <label>Current Password</label>
                    <input type="password" name="current_password" required>
                </div>
                <div class="input-group">
                    <label>New Password</label>
                    <input type="password" name="new_password" required>
                </div>
            </div>
            <button type="submit" class="btn-primary">Change Password</button>
        </form>
    </div>
</div>
<style>
.account-container { max-width: 800px; margin: 0 auto; }
.account-section { background: white; border-radius: 1.5rem; padding: 1.5rem; margin-bottom: 2rem; }
.form-row { display: flex; gap: 1rem; margin-bottom: 1rem; }
.input-group { flex: 1; }
.input-group label { display: block; margin-bottom: 0.3rem; font-weight: 600; }
.input-group input, .input-group select { width: 100%; padding: 0.6rem; border: 1px solid #ddd; border-radius: 0.5rem; }
@media (max-width: 640px) { .form-row { flex-direction: column; } }
</style>
</main>
<%- include('partials/footer') %>