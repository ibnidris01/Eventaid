<%- include('partials/header', { title: title }) %>
<%- include('partials/sidebar', { user: user }) %>
<div class="form-container">
    <h2>Upload Your Portfolio</h2>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="POST" action="/planner/upload-portfolio" enctype="multipart/form-data">
        <div class="drag-drop">Drag & drop files here or <label>Browse<input type="file" name="portfolioFile" hidden></label></div>
        <input type="text" name="title" placeholder="Project Title" required>
        <select name="category">
            <option>Wedding</option><option>Corporate</option><option>Party</option>
        </select>
        <button type="submit">Publish Portfolio</button>
    </form>
</div>
</main>
<%- include('partials/footer') %>